---
interface Props {
  title?: string;
  compact?: boolean;
  elevated?: boolean;
  class?: string;
}

const {
  title,
  compact = false,
  elevated = false,
  class: className = "",
} = Astro.props;

const classes = [
  "ds-card",
  compact ? "ds-card--compact" : "",
  elevated ? "ds-card--elevated" : "",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class={classes}>
  {title && <p class="ds-card__title">{title}</p>}
  <div class="ds-card__body">
    <slot />
  </div>
</div>

<style>
  .ds-card {
    background-color: var(--color-bg);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    transition:
      border-color var(--duration-normal) var(--ease-out-quart),
      box-shadow var(--duration-normal) var(--ease-out-quart),
      transform var(--duration-fast) var(--ease-snap);
  }

  .ds-card--elevated {
    background-color: var(--color-surface);
  }

  .ds-card:hover {
    border-color: color-mix(in oklch, var(--color-primary) 22%, var(--color-line));
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  .ds-card--compact {
    padding: var(--space-md);
  }

  .ds-card__title {
    font-family: var(--font-display);
    font-size: var(--text-subheading);
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 var(--space-sm) 0;
    max-width: none;
  }

  .ds-card__body {
    color: var(--color-muted);
    font-size: var(--text-secondary);
  }

  .ds-card__body :global(p) {
    max-width: none;
  }
</style>
